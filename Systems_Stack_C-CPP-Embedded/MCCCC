# C - POINTERS
c_pointers:
	@clear
	@echo "═══════════════════════════════════════════"
	@echo "   POINTERS - EXPLANATION"
	@echo "═══════════════════════════════════════════"
	@echo ""
	@echo "  A pointer stores a memory address."
	@echo ""
	@echo "  *ptr  - Get value at address"
	@echo "  &var  - Get address of variable"
	@echo "  ptr++ - Move to next element"
	@echo ""
	@echo "═══════════════════════════════════════════"
	@echo ""
	@echo "  1. Pointer Arithmetic"
	@echo "  2. Function Pointers"
	@echo "  3. Double Pointers"
	@echo "  0. Back"
	@echo ""
	@read -p "  Select: " opt; \
	case $$opt in \
		1) $(MAKE) run_ptr_arith ;; \
		2) $(MAKE) run_ptr_func ;; \
		3) $(MAKE) run_ptr_double ;; \
		0) $(MAKE) c_menu ;; \
	esac

run_ptr_arith:
	@clear
	@echo "═══════════════════════════════════════════"
	@echo "   POINTER ARITHMETIC"
	@echo "═══════════════════════════════════════════"
	@echo ""
	@echo "CODE:"
	@echo "  int arr[5] = {10,20,30,40,50};"
	@echo "  int *ptr = arr;"
	@echo "  printf(\"*ptr = %%d\\n\", *ptr);"
	@echo "  ptr++;"
	@echo "  printf(\"After ++: %%d\\n\", *ptr);"
	@echo ""
	@echo "OUTPUT:"
	@$(CC) $(CFLAGS) -o $(BIN_DIR)/ptr_arith 01-c-language/pointers/pointer_arithmetic.c && ./$(BIN_DIR)/ptr_arith
	@echo ""
	@read -p "  Press Enter..." dummy
	@$(MAKE) c_pointers

run_ptr_func:
	@clear
	@echo "═══════════════════════════════════════════"
	@echo "   FUNCTION POINTERS"
	@echo "═══════════════════════════════════════════"
	@echo ""
	@echo "CODE:"
	@echo "  int add(int a,int b){return a+b;}"
	@echo "  int (*op)(int,int)=add;"
	@echo "  printf(\"5+3=%%d\\n\",op(5,3));"
	@echo ""
	@echo "OUTPUT:"
	@$(CC) $(CFLAGS) -o $(BIN_DIR)/ptr_func 01-c-language/pointers/function_pointers.c && ./$(BIN_DIR)/ptr_func
