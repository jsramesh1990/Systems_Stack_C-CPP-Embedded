	@echo "  ┌─────────────────────────────────────────────────────┐"
	@echo "  │  WHAT ARE POINTERS?                                 │"
	@echo "  ├─────────────────────────────────────────────────────┤"
	@echo "  │  A pointer stores a memory address instead of a     │"
	@echo "  │  value. It points to the location of data.          │"
	@echo "  │                                                     │"
	@echo "  │  *ptr - Dereference (get value at address)          │"
	@echo "  │  &var - Address of operator                         │"
	@echo "  │  ptr++ - Move to next element                       │"
	@echo "  └─────────────────────────────────────────────────────┘"
	@echo ""
	@echo "  ┌─────────────────────────────────────────────────────┐"
	@echo "  │  EXAMPLES                                           │"
	@echo "  ├─────────────────────────────────────────────────────┤"
	@echo "  │  1. Pointer Arithmetic                              │"
	@echo "  │  2. Function Pointers                               │"
	@echo "  │  3. Double Pointers                                 │"
	@echo "  │  4. NULL & Dangling Pointers                        │"
	@echo "  │  0. Back to C Menu                                  │"
	@echo "  └─────────────────────────────────────────────────────┘"
	@echo ""
	@read -p "  Select example: " opt; \
	case $$opt in \
		1) $(MAKE) run_ptr_arith ;; \
		2) $(MAKE) run_ptr_func ;; \
		3) $(MAKE) run_ptr_double ;; \
		4) $(MAKE) run_ptr_null ;; \
		0) $(MAKE) c_menu ;; \
		*) echo "  Invalid"; sleep 1; $(MAKE) c_pointers_menu ;; \
	esac

run_ptr_arith:
	@clear
	@echo "╔══════════════════════════════════════════════════════════╗"
	@echo "║              POINTER ARITHMETIC                          ║"
	@echo "╚══════════════════════════════════════════════════════════╝"
	@echo ""
	@echo "  ┌─────────────────────────────────────────────────────┐"
	@echo "  │  CODE                                               │"
	@echo "  ├─────────────────────────────────────────────────────┤"
	@echo "  │  int arr[5] = {10, 20, 30, 40, 50};                │"
	@echo "  │  int *ptr = arr;                                   │"
	@echo "  │  printf(\"*ptr = %%d\\n\", *ptr);                    │"
	@echo "  │  ptr++;                                            │"
	@echo "  │  printf(\"After ++: %%d\\n\", *ptr);                 │"
	@echo "  └─────────────────────────────────────────────────────┘"
	@echo ""
	@echo "  ┌─────────────────────────────────────────────────────┐"
	@echo "  │  OUTPUT                                             │"
	@echo "  ├─────────────────────────────────────────────────────┤"
	@$(CC) $(CFLAGS) -o $(BIN_DIR)/ptr_arith 01-c-language/pointers/pointer_arithmetic.c && ./$(BIN_DIR)/ptr_arith
	@echo "  └─────────────────────────────────────────────────────┘"
	@echo ""
	@echo "  ┌─────────────────────────────────────────────────────┐"
	@echo "  │  EXPLANATION                                        │"
	@echo "  ├─────────────────────────────────────────────────────┤"
	@echo "  │  When you do ptr++, the pointer moves forward by    │"
	@echo "  │  sizeof(int) bytes. On this system, int is 4 bytes. │"
	@echo "  │  So ptr moves from arr[0] to arr[1].                │"
	@echo "  └─────────────────────────────────────────────────────┘"
	@echo ""
	@read -p "  Press Enter to continue..." dummy
	@$(MAKE) c_pointers_menu

