# ============================================================
# SYSTEMS STACK: C, C++, EMBEDDED
# Single Makefile with Interactive Menu
# ============================================================

CC = gcc
CXX = g++
CFLAGS = -Wall -Wextra -std=c11 -O2
CXXFLAGS = -Wall -Wextra -std=c++20 -O2

BIN_DIR = bin
$(shell mkdir -p $(BIN_DIR))

.PHONY: all clean

all: menu

# ============================================================
# MAIN MENU
# ============================================================

menu:
	@clear
	@echo "╔══════════════════════════════════════════════════════════╗"
	@echo "║         SYSTEMS STACK: C, C++, EMBEDDED                  ║"
	@echo "║              From Source to Silicon                       ║"
	@echo "╚══════════════════════════════════════════════════════════╝"
	@echo ""
	@echo "  ┌─────────────────────────────────────────────────────┐"
	@echo "  │  MAIN MENU                                          │"
	@echo "  ├─────────────────────────────────────────────────────┤"
	@echo "  │  1. C Language                                      │"
	@echo "  │  2. C++ Language                                    │"
	@echo "  │  3. Embedded Baremetal                              │"
	@echo "  │  4. Exercises                                       │"
	@echo "  │  5. Clean                                           │"
	@echo "  │  0. Exit                                            │"
	@echo "  └─────────────────────────────────────────────────────┘"
	@echo ""
	@read -p "  Select option: " opt; \
	case $$opt in \
		1) $(MAKE) c_menu ;; \
		2) $(MAKE) cpp_menu ;; \
		3) $(MAKE) embedded_menu ;; \
		4) $(MAKE) exercises_menu ;; \
		5) $(MAKE) clean ;; \
